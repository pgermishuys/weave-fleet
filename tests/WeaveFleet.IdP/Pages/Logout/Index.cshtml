@page
@model WeaveFleet.IdP.Pages.Logout.IndexModel
@{
    ViewData["Title"] = "Signed Out";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Signed Out — WeaveFleet Test IdP</title>
    <style>
        body { font-family: sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; background: #f5f5f5; }
        .box { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.12); min-width: 320px; text-align: center; }
        a { color: #2563eb; }
    </style>
</head>
<body>
    <div class="box" data-testid="logout-page">
        @if (Model.ShowSignoutPrompt)
        {
            <h1>Sign out?</h1>
            <form method="post">
                <input type="hidden" asp-for="LogoutId" />
                <button type="submit" data-testid="logout-confirm">Yes, sign me out</button>
            </form>
        }
        else
        {
            <h1>You are now signed out</h1>
            <p><a href="~/" data-testid="logout-home">Return to home</a></p>
        }
    </div>
</body>
</html>
