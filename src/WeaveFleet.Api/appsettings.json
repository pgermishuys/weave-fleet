{
  "Fleet": {
    "Port": 3000,
    "Host": "127.0.0.1",
    "DiagnosticLogging": {
      "Enabled": true,
      "MinimumLevel": "Debug",
      "RetentionDays": 30
    },
    "Telemetry": {
      "Enabled": true,
      "OtlpEndpoint": "http://localhost:4317"
    },
    "ClaudeCode": {
      "BinaryPath": "claude",
      "PermissionMode": "bypassPermissions",
      "ProcessTimeoutSeconds": 300
    },
    "Outbox": {
      "PollIntervalMilliseconds": 1000,
      "EmptyPollSleepMilliseconds": 250,
      "DispatchBatchSize": 100,
      "CleanupIntervalMinutes": 15,
      "RetentionHours": 24,
      "CleanupBatchSize": 500
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.OtlpTraceExporter": "Warning",
      "System.Net.Http.HttpClient.OtlpMetricExporter": "Warning",
      "System.Net.Http.HttpClient.OtlpLogExporter": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "HH:mm:ss.fff "
      }
    }
  },
  "AllowedHosts": "*"
}
