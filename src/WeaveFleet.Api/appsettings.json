{
  "Fleet": {
    "Port": 3000,
    "Host": "127.0.0.1",
    "Telemetry": {
      "Enabled": true,
      "OtlpEndpoint": "http://localhost:4317",
      "ConsoleExporterEnabled": false
    },
    "ClaudeCode": {
      "BinaryPath": "claude",
      "PermissionMode": "bypassPermissions",
      "ProcessTimeoutSeconds": 300
    }
  },
  "Urls": "http://127.0.0.1:5001",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
