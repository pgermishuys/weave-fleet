<?xml version="1.0" encoding="utf-8"?>
<!--
  Production publish profile.

  Usage:
    # Step 1: Build the frontend SPA
    cd client && npm run build:spa

    # Step 2: Publish the .NET backend (copies wwwroot/ into the output)
    dotnet publish src/WeaveFleet.Api -c Release -o publish/

    # Step 3: Run the published artifact
    ./publish/WeaveFleet.Api     (Linux/macOS)
    publish\WeaveFleet.Api.exe   (Windows)
    # → http://localhost:3000
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>..\..\..\..\publish\</PublishDir>
    <SelfContained>false</SelfContained>
  </PropertyGroup>
</Project>
