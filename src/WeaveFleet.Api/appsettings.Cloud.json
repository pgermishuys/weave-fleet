{
  "Fleet": {
    "Port": 8080,
    "Host": "0.0.0.0",
    "DatabasePath": "/data/weave-fleet.db",
    "AnalyticsDatabasePath": "/data/weave-fleet-analytics.db",
    "Auth": {
      "Enabled": true,
      "Authority": "https://demo.duendesoftware.com/",
      "ClientId": "interactive.confidential",
      "ClientSecret": "secret",
      "CallbackPath": "/auth/callback",
      "SignedOutCallbackPath": "/auth/signed-out",
      "AllowedOrigins": [
        "https://localhost:3001"
      ],
      "CookieName": ".WeaveFleet.Auth",
      "CookieExpirationMinutes": 1440
    },
    "Cloud": {
      "Enabled": true,
      "WorkspaceRoot": "/data/workspaces"
    },
    "Harness": {
      "PooledOpenCodeHarness": false,
      "PooledOpenCodeIdleTtlSeconds": 60
    },
    "ClaudeCode": {
      "BinaryPath": "claude",
      "PermissionMode": "bypassPermissions",
      "ProcessTimeoutSeconds": 300
    },
    "Outbox": {
      "PollIntervalMilliseconds": 1000,
      "EmptyPollSleepMilliseconds": 250,
      "DispatchBatchSize": 100,
      "CleanupIntervalMinutes": 15,
      "RetentionHours": 24,
      "CleanupBatchSize": 500
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
