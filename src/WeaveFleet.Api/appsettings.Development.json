{
  "Fleet": {
    "Telemetry": {
      "OtlpEndpoint": "http://localhost:5341/ingest/otlp"
    },
    "Port": 5001,
    "Host": "0.0.0.0",
    "Auth": {
      "Enabled": false,
      "Authority": "https://demo.duendesoftware.com/",
      "ClientId": "interactive.confidential",
      "ClientSecret": "secret",
      "CallbackPath": "/auth/callback",
      "SignedOutCallbackPath": "/auth/signed-out",
      "AllowedOrigins": [
        "http://weave-fleet-dev.localhost:3001",
        "https://weave-fleet-dev.localhost:3001"
      ],
      "CookieName": ".WeaveFleet.Auth",
      "CookieExpirationMinutes": 1440
    },
    "Cloud": {
      "Enabled": false,
      "WorkspaceRoot": "/data/workspaces"
    },
    "ClaudeCode": {
      "BinaryPath": "claude",
      "PermissionMode": "bypassPermissions",
      "ProcessTimeoutSeconds": 300
    },
    "Outbox": {
      "PollIntervalMilliseconds": 1000,
      "EmptyPollSleepMilliseconds": 250,
      "DispatchBatchSize": 100,
      "CleanupIntervalMinutes": 15,
      "RetentionHours": 24,
      "CleanupBatchSize": 500
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "System.Net.Http.HttpClient.OtlpTraceExporter": "Warning",
      "System.Net.Http.HttpClient.OtlpMetricExporter": "Warning",
      "System.Net.Http.HttpClient.OtlpLogExporter": "Warning"
    }
  }
}
